# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/chat_personalization

# Application Settings
APP_NAME=Chat Personalization Service
DEBUG=False
ENVIRONMENT=development

# API Settings
API_VERSION=1.0.0
API_PREFIX=/api/v1

# LLM Context
MAX_CONTEXT_LENGTH=2000
ENABLE_CONTEXT_CACHING=True

# Analysis Settings
MIN_PROMPTS_FOR_ANALYSIS=3
MAX_PROMPTS_TO_ANALYZE=100
ANALYSIS_BATCH_SIZE=20

# Features
ENABLE_REAL_TIME_UPDATE=True
ENABLE_SENTIMENT_ANALYSIS=True
ENABLE_TOPIC_MODELING=False

# Logging
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8001
